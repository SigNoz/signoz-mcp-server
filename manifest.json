{
  "manifest_version": "0.2",
  "name": "signoz",
  "display_name": "SigNoz MCP Server",
  "version": "0.2.1",
  "description": "Access SigNoz metrics, traces, logs, and dashboards.",
  "author": {
    "name": "SigNoz Team"
  },
  "homepage": "https://github.com/SigNoz/signoz-mcp-server",
  "documentation": "https://signoz.io/docs/signoz-mcp-server",
  "support": "https://github.com/SigNoz/signoz-mcp-server/issues",
  "icon": "signoz_icon.png",
  "server": {
    "type": "binary",
    "entry_point": "server/signoz-mcp-server",
    "mcp_config": {
      "command": "${__dirname}/server/signoz-mcp-server",
      "args": [],
      "env": {
        "SIGNOZ_URL": "${user_config.signoz_url}",
        "SIGNOZ_API_KEY": "${user_config.signoz_api_key}",
        "LOG_LEVEL": "${user_config.log_level}"
      }
    }
  },
  "tools": [
    {
      "name": "signoz_list_metrics",
      "description": "Search and list available metrics from SigNoz"
    },
    {
      "name": "signoz_query_metrics",
      "description": "Query metrics with smart aggregation defaults based on metric type"
    },
    {
      "name": "signoz_get_field_keys",
      "description": "Get available field keys for metrics, traces, or logs"
    },
    {
      "name": "signoz_get_field_values",
      "description": "Get possible values for a field key for metrics, traces, or logs"
    },
    {
      "name": "signoz_list_alerts",
      "description": "List firing/silenced/inhibited Alertmanager alert *instances* (not rule definitions) with optional matcher/receiver filtering"
    },
    {
      "name": "signoz_get_alert",
      "description": "Get an alert rule definition by ID via GET /api/v2/rules/{ruleId}. Response shape differs by server version (v2 Rule vs v1 GettableRule)"
    },
    {
      "name": "signoz_get_alert_history",
      "description": "Get alert state history timeline for a specific rule with optional state filter"
    },
    {
      "name": "signoz_create_alert",
      "description": "Create a new alert rule via POST /api/v2/rules. Threshold/PromQL rules use v2alpha1; anomaly rules use the v1 schema (top-level evalWindow/frequency, condition-level op/matchType/target/algorithm/seasonality)"
    },
    {
      "name": "signoz_update_alert",
      "description": "Update an existing alert rule by UUIDv7 via PUT /api/v2/rules/{ruleId}"
    },
    {
      "name": "signoz_delete_alert",
      "description": "Delete an alert rule by UUIDv7 via DELETE /api/v2/rules/{ruleId}"
    },
    {
      "name": "signoz_list_dashboards",
      "description": "List all dashboards with summaries"
    },
    {
      "name": "signoz_get_dashboard",
      "description": "Get full dashboard configuration by UUID"
    },
    {
      "name": "signoz_create_dashboard",
      "description": "Create a new monitoring dashboard"
    },
    {
      "name": "signoz_update_dashboard",
      "description": "Update an existing dashboard by UUID"
    },
    {
      "name": "signoz_delete_dashboard",
      "description": "Delete a dashboard by UUID"
    },
    {
      "name": "signoz_list_services",
      "description": "List services within a given time range"
    },
    {
      "name": "signoz_get_service_top_operations",
      "description": "Get top operations for a service"
    },
    {
      "name": "signoz_list_views",
      "description": "List SigNoz saved Explorer views for a given sourcePage (traces, logs, or metrics), with optional name/category filters"
    },
    {
      "name": "signoz_get_view",
      "description": "Get a single SigNoz saved view by UUID"
    },
    {
      "name": "signoz_create_view",
      "description": "Create a new SigNoz saved Explorer view"
    },
    {
      "name": "signoz_update_view",
      "description": "Replace an existing SigNoz saved view (full-body PUT)"
    },
    {
      "name": "signoz_delete_view",
      "description": "Delete a SigNoz saved view by UUID"
    },
    {
      "name": "signoz_aggregate_logs",
      "description": "Aggregate logs to compute statistics (count, avg, sum, min, max, percentiles)"
    },
    {
      "name": "signoz_search_logs",
      "description": "Search logs with flexible filtering by service, severity, and body text"
    },
    {
      "name": "signoz_aggregate_traces",
      "description": "Aggregate traces to compute statistics over spans, optionally grouped by fields"
    },
    {
      "name": "signoz_search_traces",
      "description": "Search traces with flexible filtering by service, operation, error, and duration"
    },
    {
      "name": "signoz_get_trace_details",
      "description": "Get comprehensive trace information including all spans and hierarchy"
    },
    {
      "name": "signoz_execute_builder_query",
      "description": "Execute a raw SigNoz Query Builder v5 query"
    },
    {
      "name": "signoz_list_notification_channels",
      "description": "List all configured notification channels"
    },
    {
      "name": "signoz_create_notification_channel",
